# Environment (development|preproduction|production)
ENV=development

# Used to uniquely identify your Docker project
PROJECT_NAME=perseid

# Which examples project you want to play with (jobs)
EXAMPLES_PROJECT=jobs

# Which network interface should expose project ports
HOST_IP=127.0.0.1

# Examples port
EXAMPLES_PORT=5070

# CIDR to use to create your app docker network
DOCKER_SUBNET=172.72.59.0/24