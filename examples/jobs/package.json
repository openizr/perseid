{
  "type": "module",
  "main": "./init.js",
  "license": "UNLICENSED",
  "devDependencies": {
    "typescript-dev-kit": "^6.0.7"
  },
  "dependencies": {
    "@perseid/jobs": "file:../../../../jobs/dist",
    "@perseid/server": "^0.0.55",
    "axios": "^1.4.0"
  },
  "tsDevKitConfig": {
    "target": "node",
    "entries": {
      "main": "./scripts/main.ts",
      "init": "./scripts/init.ts",
      "runJob": "./scripts/runJob.ts"
    },
    "srcPath": "src",
    "distPath": "dist",
